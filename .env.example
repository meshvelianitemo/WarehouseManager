# ============================================================
#  Template for the compose secrets file.
#  Copy this to `.env` and fill in real values:
#      cp .env.example .env
#  `.env` is gitignored; this template is safe to commit.
# ============================================================

# SQL Server SA password — 8+ chars, upper + lower + digit + symbol.
MSSQL_SA_PASSWORD=ChangeMe_Strong1!

# Seq first-run admin password.
SEQ_ADMIN_PASSWORD=ChangeMe_Seq1!
